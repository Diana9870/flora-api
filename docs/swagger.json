{
  "openapi": "3.0.3",
  "info": {
    "title": "Flora API",
    "description": "REST API for the Flora shop — bouquets (CRUD, favorite toggling, photo upload), bestsellers (CRUD, photo upload), customer feedback (CRUD), order requests and newsletter subscribers.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Local development"
    },
    {
      "url": "https://flora-api-q559.onrender.com/api",
      "description": "Production (Render)"
    }
  ],
  "tags": [
    {
      "name": "Bouquets",
      "description": "Endpoints for the bouquets collection"
    },
    {
      "name": "Bestsellers",
      "description": "Endpoints for the bestsellers collection"
    },
    {
      "name": "Feedback",
      "description": "Endpoints for customer feedback"
    },
    {
      "name": "Orders",
      "description": "Endpoints for order requests submitted from the storefront"
    },
    {
      "name": "Subscribers",
      "description": "Endpoints for newsletter subscribers"
    }
  ],
  "paths": {
    "/bouquets": {
      "get": {
        "tags": [
          "Bouquets"
        ],
        "summary": "Get all bouquets",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "description": "Page number (optional, requires limit)"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "description": "Items per page (optional, requires page)"
          },
          {
            "name": "category",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filter by category"
          }
        ],
        "responses": {
          "200": {
            "description": "List of bouquets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "bouquets": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Bouquet"
                      }
                    },
                    "total": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Bouquets"
        ],
        "summary": "Create a new bouquet",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BouquetCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Bouquet created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Bouquet"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/bouquets/{id}": {
      "get": {
        "tags": [
          "Bouquets"
        ],
        "summary": "Get a bouquet by id",
        "parameters": [
          {
            "$ref": "#/components/parameters/BouquetId"
          }
        ],
        "responses": {
          "200": {
            "description": "Bouquet found",
