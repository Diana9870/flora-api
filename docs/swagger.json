      "put": {
        "tags": [
          "Bouquets"
        ],
        "summary": "Update a bouquet",
        "parameters": [
          {
            "$ref": "#/components/parameters/BouquetId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BouquetUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bouquet updated",
