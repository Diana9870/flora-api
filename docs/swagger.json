    "/orders": {
      "post": {
        "tags": [
          "Orders"
        ],
        "summary": "Submit a new order request",
        "description": "Used by the storefront's order modal to send a contact-style order request (name, phone, email, optional message).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Order created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Order"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/subscribers": {
      "post": {
        "tags": [
          "Subscribers"
        ],
        "summary": "Subscribe an email to the newsletter",
        "description": "Used by the footer's \"Subscribe for updates\" form.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubscriberCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Subscribed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Subscriber"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "Email is already subscribed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "BouquetId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer"
        },
        "description": "Bouquet id"
      },
      "BestsellerId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer"
        },
        "description": "Bestseller id"
      },
      "FeedbackId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer"
        },
        "description": "Feedback id"
      }
    },
    "schemas": {
      "Bouquet": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "Peach Meadow",
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "example": "A soft and radiant arrangement of peach and blush roses.",
            "maxLength": 1000
          },
          "price": {
            "type": "number",
            "example": 55,
            "exclusiveMinimum": 0
          },
          "category": {
            "type": "string",
            "example": "basket",
            "maxLength": 50
          },
          "photoURL": {
            "type": "string",
            "format": "uri",
            "example": "https://flora-api.onrender.com/photos/167..._rose.jpg"
          },
          "favorite": {
            "type": "boolean",
            "example": false
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "BouquetCreate": {
        "type": "object",
        "required": [
          "title",
          "description",
          "price"
        ],
        "properties": {
          "title": {
            "type": "string",
            "example": "Peach Meadow",
            "minLength": 2,
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "example": "A soft and radiant arrangement of peach and blush roses.",
            "minLength": 2,
            "maxLength": 1000
          },
          "price": {
            "type": "number",
            "example": 55,
            "exclusiveMinimum": 0
          },
          "category": {
            "type": "string",
            "example": "basket",
            "maxLength": 50
          },
          "favorite": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "BouquetUpdate": {
        "type": "object",
        "minProperties": 1,
        "description": "At least one field is required — an empty body returns 400.",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 2,
            "maxLength": 100
          },
          "description": {
            "type": "string",
            "minLength": 2,
            "maxLength": 1000
          },
          "price": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "category": {
            "type": "string",
            "maxLength": 50
          },
          "favorite": {
            "type": "boolean"
          }
        }
      },
