{
  "openapi": "3.0.3",
  "info": {
    "title": "Flora API",
    "description": "REST API for the Flora shop — bouquets (CRUD, favorite toggling, photo upload), bestsellers (CRUD, photo upload) and customer feedback (CRUD).",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "http://localhost:3000/api", "description": "Local development" },
    { "url": "https://flora-api-q559.onrender.com/api", "description": "Production (Render)" }
  ],
  "tags": [
    { "name": "Bouquets", "description": "Endpoints for the bouquets collection" },
    { "name": "Bestsellers", "description": "Endpoints for the bestsellers collection" },
    { "name": "Feedback", "description": "Endpoints for customer feedback" }
  ],
  "paths": {
    "/bouquets": {
      "get": {
        "tags": ["Bouquets"],
        "summary": "Get all bouquets",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1 }, "description": "Page number (optional, requires limit)" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1 }, "description": "Items per page (optional, requires page)" },
          { "name": "category", "in": "query", "schema": { "type": "string" }, "description": "Filter by category" }
        ],
        "responses": {
          "200": {
            "description": "List of bouquets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "bouquets": { "type": "array", "items": { "$ref": "#/components/schemas/Bouquet" } },
                    "total": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Bouquets"],
        "summary": "Create a new bouquet",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BouquetCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Bouquet created",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Bouquet" } }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      }
    },
    "/bouquets/{id}": {
      "get": {
        "tags": ["Bouquets"],
        "summary": "Get a bouquet by id",
        "parameters": [{ "$ref": "#/components/parameters/BouquetId" }],
        "responses": {
          "200": {
            "description": "Bouquet found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Bouquet" } } }
          },
          "404": {
            "description": "Not found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "put": {
        "tags": ["Bouquets"],
        "summary": "Update a bouquet",
        "parameters": [{ "$ref": "#/components/parameters/BouquetId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/BouquetUpdate" } }
          }
        },
        "responses": {
          "200": {
            "description": "Bouquet updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Bouquet" } } }
          },
          "400": {
            "description": "Empty or invalid body",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "404": {
            "description": "Not found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "delete": {
        "tags": ["Bouquets"],
        "summary": "Delete a bouquet",
        "parameters": [{ "$ref": "#/components/parameters/BouquetId" }],
        "responses": {
          "200": {
            "description": "Bouquet deleted",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Bouquet" } } }
          },
          "404": {
            "description": "Not found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/bouquets/{id}/favorite": {
      "patch": {
        "tags": ["Bouquets"],
        "summary": "Update the favorite status of a bouquet",
        "parameters": [{ "$ref": "#/components/parameters/BouquetId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/FavoriteUpdate" } }
          }
        },
        "responses": {
          "200": {
            "description": "Favorite status updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Bouquet" } } }
          },
          "400": {
            "description": "Validation error",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "404": {
            "description": "Not found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/bouquets/{id}/photo": {
      "patch": {
        "tags": ["Bouquets"],
        "summary": "Upload/replace the bouquet's photo",
        "parameters": [{ "$ref": "#/components/parameters/BouquetId" }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "photo": { "type": "string", "format": "binary" }
                },
                "required": ["photo"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Photo updated, returns the bouquet with its new photoURL",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Bouquet" } } }
          },
          "400": {
            "description": "Missing or invalid file",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "404": {
            "description": "Not found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/bestsellers": {
      "get": {
        "tags": ["Bestsellers"],
        "summary": "Get all bestsellers",
        "description": "Returns bestsellers ordered by salesCount (descending) by default.",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1 }, "description": "Page number (optional, requires limit)" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1 }, "description": "Items per page (optional, requires page)" },
          { "name": "category", "in": "query", "schema": { "type": "string" }, "description": "Filter by category" }
        ],
        "responses": {
          "200": {
            "description": "List of bestsellers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "bestsellers": { "type": "array", "items": { "$ref": "#/components/schemas/Bestseller" } },
                    "total": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Bestsellers"],
        "summary": "Create a new bestseller",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BestsellerCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Bestseller created",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Bestseller" } }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      }
    },
    "/bestsellers/{id}": {
      "get": {
        "tags": ["Bestsellers"],
        "summary": "Get a bestseller by id",
        "parameters": [{ "$ref": "#/components/parameters/BestsellerId" }],
        "responses": {
          "200": {
            "description": "Bestseller found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Bestseller" } } }
          },
          "404": {
            "description": "Not found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "put": {
        "tags": ["Bestsellers"],
        "summary": "Update a bestseller",
        "parameters": [{ "$ref": "#/components/parameters/BestsellerId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/BestsellerUpdate" } }
          }
        },
        "responses": {
          "200": {
            "description": "Bestseller updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Bestseller" } } }
          },
          "400": {
            "description": "Empty or invalid body",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "404": {
            "description": "Not found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "delete": {
        "tags": ["Bestsellers"],
        "summary": "Delete a bestseller",
        "parameters": [{ "$ref": "#/components/parameters/BestsellerId" }],
        "responses": {
          "200": {
            "description": "Bestseller deleted",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Bestseller" } } }
          },
          "404": {
            "description": "Not found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/bestsellers/{id}/photo": {
      "patch": {
        "tags": ["Bestsellers"],
        "summary": "Upload/replace the bestseller's photo",
        "parameters": [{ "$ref": "#/components/parameters/BestsellerId" }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "photo": { "type": "string", "format": "binary" }
                },
                "required": ["photo"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Photo updated, returns the bestseller with its new photoURL",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Bestseller" } } }
          },
          "400": {
            "description": "Missing or invalid file",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "404": {
            "description": "Not found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/feedback": {
      "get": {
        "tags": ["Feedback"],
        "summary": "Get all feedback",
        "description": "Returns feedback ordered by creation date (newest first) by default.",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1 }, "description": "Page number (optional, requires limit)" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1 }, "description": "Items per page (optional, requires page)" }
        ],
        "responses": {
          "200": {
            "description": "List of feedback entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "feedback": { "type": "array", "items": { "$ref": "#/components/schemas/Feedback" } },
                    "total": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Feedback"],
        "summary": "Create a new feedback entry",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/FeedbackCreate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Feedback created",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Feedback" } }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      }
    },
    "/feedback/{id}": {
      "get": {
        "tags": ["Feedback"],
        "summary": "Get a feedback entry by id",
        "parameters": [{ "$ref": "#/components/parameters/FeedbackId" }],
        "responses": {
          "200": {
            "description": "Feedback found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Feedback" } } }
          },
          "404": {
            "description": "Not found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "put": {
        "tags": ["Feedback"],
        "summary": "Update a feedback entry",
        "parameters": [{ "$ref": "#/components/parameters/FeedbackId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/FeedbackUpdate" } }
          }
        },
        "responses": {
          "200": {
            "description": "Feedback updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Feedback" } } }
          },
          "400": {
            "description": "Empty or invalid body",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          },
          "404": {
            "description": "Not found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      },
      "delete": {
        "tags": ["Feedback"],
        "summary": "Delete a feedback entry",
        "parameters": [{ "$ref": "#/components/parameters/FeedbackId" }],
        "responses": {
          "200": {
            "description": "Feedback deleted",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Feedback" } } }
          },
          "404": {
            "description": "Not found",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "BouquetId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Bouquet id"
      },
      "BestsellerId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Bestseller id"
      },
      "FeedbackId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Feedback id"
      }
    },
    "schemas": {
      "Bouquet": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "title": { "type": "string", "example": "Peach Meadow" },
          "description": { "type": "string", "example": "A soft and radiant arrangement of peach and blush roses." },
          "price": { "type": "number", "example": 55 },
          "category": { "type": "string", "example": "basket" },
          "photoURL": { "type": "string", "format": "uri", "example": "https://flora-api.onrender.com/photos/167..._rose.jpg" },
          "favorite": { "type": "boolean", "example": false },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "BouquetCreate": {
        "type": "object",
        "required": ["title", "description", "price"],
        "properties": {
          "title": { "type": "string", "example": "Peach Meadow" },
          "description": { "type": "string", "example": "A soft and radiant arrangement of peach and blush roses." },
          "price": { "type": "number", "example": 55 },
          "category": { "type": "string", "example": "basket" },
          "favorite": { "type": "boolean", "default": false }
        }
      },
      "BouquetUpdate": {
        "type": "object",
        "minProperties": 1,
        "description": "At least one field is required — an empty body returns 400.",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "number" },
          "category": { "type": "string" },
          "favorite": { "type": "boolean" }
        }
      },
      "FavoriteUpdate": {
        "type": "object",
        "required": ["favorite"],
        "properties": {
          "favorite": { "type": "boolean", "example": true }
        }
      },
      "Bestseller": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "title": { "type": "string", "example": "Crimson Romance" },
          "description": { "type": "string", "example": "Our #1 best-seller: premium red roses in a classic hand-tied arrangement." },
          "price": { "type": "number", "example": 55 },
          "category": { "type": "string", "example": "roses" },
          "photoURL": { "type": "string", "format": "uri", "example": "https://flora-api.onrender.com/photos/bouquet-1.jpg" },
          "salesCount": { "type": "integer", "example": 482, "description": "Number of times this bouquet has been sold — used to rank the list." },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "BestsellerCreate": {
        "type": "object",
        "required": ["title", "description", "price"],
        "properties": {
          "title": { "type": "string", "example": "Crimson Romance" },
          "description": { "type": "string", "example": "Our #1 best-seller: premium red roses in a classic hand-tied arrangement." },
          "price": { "type": "number", "example": 55 },
          "category": { "type": "string", "example": "roses" },
          "salesCount": { "type": "integer", "default": 0 }
        }
      },
      "BestsellerUpdate": {
        "type": "object",
        "minProperties": 1,
        "description": "At least one field is required — an empty body returns 400.",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "number" },
          "category": { "type": "string" },
          "salesCount": { "type": "integer" }
        }
      },
      "Feedback": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "author": { "type": "string", "example": "Emma T." },
          "text": { "type": "string", "example": "Flora made my anniversary unforgettable with their beautiful arrangement!" },
          "rating": { "type": "integer", "minimum": 1, "maximum": 5, "example": 5 },
          "avatarURL": { "type": "string", "format": "uri", "example": "https://gravatar.com/avatar/....png" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "FeedbackCreate": {
        "type": "object",
        "required": ["author", "text"],
        "properties": {
          "author": { "type": "string", "example": "Emma T." },
          "text": { "type": "string", "example": "Flora made my anniversary unforgettable with their beautiful arrangement!" },
          "rating": { "type": "integer", "minimum": 1, "maximum": 5, "default": 5 }
        }
      },
      "FeedbackUpdate": {
        "type": "object",
        "minProperties": 1,
        "description": "At least one field is required — an empty body returns 400.",
        "properties": {
          "author": { "type": "string" },
          "text": { "type": "string" },
          "rating": { "type": "integer", "minimum": 1, "maximum": 5 }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": { "type": "string", "example": "Not found" }
        }
      }
    }
  }
}
