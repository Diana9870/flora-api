{
  "name": "flora-api",
  "version": "1.0.0",
  "description": "Flora REST API (bouquets, bestsellers, feedback) — Express + Sequelize (PostgreSQL) + Joi + Multer + Swagger",
  "type": "commonjs",
  "main": "server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
  "start": "node server.js",
  "dev": "node --watch server.js",

  "seed": "npm run seed:all",

  "seed:bouquets": "node seed/seedBouquets.js",
  "seed:bestsellers": "node seed/seedBestsellers.js",
  "seed:feedback": "node seed/seedFeedback.js",

  "seed:all": "npm run seed:bouquets && npm run seed:bestsellers && npm run seed:feedback"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "gravatar": "^1.8.2",
    "joi": "^17.13.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  }
}
